float $num1 = 2.0;
float $num2 = 6.0;// Function to calculate the sum of float values

global proc float calculateSum(float $num1, float $num2) 
{
    float $sum = $num1 + $num2;
    return $sum;
}


float $sumResult = calculateSum($num1, $num2);
print("Sum: " + $sumResult + "\n");

// Function to calculate the difference of float values
global proc float calculateDifference(float $num1, float $num2) 
{
    float $result = $num1 - $num2;
    return $result;
}
 
 float $differenceResult = calculateDifference($num1, $num2);
    print("Difference: " + $differenceResult + "\n");

// Function to calculate the product (multiplication) of float values
global proc float calculateProduct(float $num1, float $num2) {
    float $result = $num1 * $num2;
    return $result;
}

float $productResult = calculateProduct($num1, $num2);
print("Product: " + $productResult + "\n");

// Function to calculate the division of float values
global proc float calculateDivision(float $num1, float $num2) 
{
    if ($num2 != 0) {
        float $result = $num1 / $num2;
        return $result;
    } else {
        error("Cannot divide by zero.");
    }
}
float $divisionResult = calculateDivision($num1, $num2);
print("Division: " + $divisionResult + "\n");

// Function to calculate x raised to the power n
global proc float calculatePower(float $x, int $n) 
{
    float $result = pow($x, $n);
    return $result;
}

int $powerExponent = 3;
float $powerResult = calculatePower($num1, $powerExponent);
print("Power: " + $powerResult + "\n");

// Function to calculate the mean (average) of float values
global proc float calculateMean(float $values[]) 
{
    float $sum = 0;
    int $count = 0;

    for ($val in $values) {
        $sum += $val;
        $count++;
    }

    float $mean = ($count > 0) ? $sum / $count : 0;
    return $mean;
}

float $values[] = {5.0, 3.0, 7.0};
float $meanResult = calculateMean($values);
print("Mean: " + $meanResult + "\n");

// Function to calculate the median of float values
global proc float calculateMedian(float $values[]) 
{
    float $sortedValues[] = `sort $values`;
    int $mid = size($sortedValues) / 2;

    if (size($sortedValues) % 2 == 0) {
        return ($sortedValues[$mid - 1] + $sortedValues[$mid]) / 2;
    } else {
        return $sortedValues[$mid];
    }
    
}
float $medianResult = calculateMedian($values);
print("Median: " + $medianResult + "\n");